{
  "name": "localghost",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": "26"
  },
  "type": "module",
  "devDependencies": {
    "@sindresorhus/slugify": "^3",
    "autoprefixer": "^10.4.19",
    "eslint": "^10",
    "jsdom": "29.1.1",
    "markdown-it-anchor": "^9",
    "markdown-it-attrs": "^5",
    "md5": "^2.3.0",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.1",
    "@remy/webmention": "^1.5.0",
    "cssnano": "^8",
    "date-fns": "^4",
    "eleventy-plugin-redirects": "1.0.0",
    "markdown-it-image-figures": "2.1.1",
    "sanitize-html": "^2.13.0",
    "sass": "^1.100.0",
    "sharp": "0.34.5",
    "uglify-js": "^3.19.3"
  },
  "prettier": {
    "tabWidth": 2,
    "printWidth": 140,
    "proseWrap": "preserve"
  },
  "scripts": {
    "start": "NODE_ENV=development BASE_URL=http://localhost:8080 eleventy --serve --quiet",
    "build": "NODE_ENV=production eleventy",
    "test": "vitest",
    "full-build": "set CACHE_BUST=true && npm run build",
    "generate-links": "node scripts/compile-links.js",
    "postbuild": "scripts/send-webmentions",
    "send-webmentions": "webmention _site/feed.xml --limit 1 --send",
    "clear-og": "rm src/static/og-images/*"
  }
}