{% extends "base.njk" %}
{% block content %}
  <article class="content h-entry">
    <h1 class="page-heading p-name">{{ title }}</h1>
    <div class="content-inner flow" {% if subtitle %} data-with-subtitle {% endif %}>
      {% if subtitle %}
        <span class="post-subtitle">{{ subtitle }}</span>
      {% endif %}
      <div class="post-metadata">
        <time class="dt-published" datetime="{{ date | w3DateFilter }}">{{ date | dateFilter }}</time>
        {% if tags %}
          <div class="tags">
            <span id="tags-desc">Tags:</span>
            <ul class="tag-list" aria-describedby="tags-desc">
              {% for tag in tags %}
                <li class="p-category">
                  <a href="/tags/{{ tag | slugify }}/">{{ tag }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
      <div class="e-content flow">
      {{ content | safe }}
      </div>
      </div>
      <aside class="p-author">
        This post was written by a human called <a href="/about">Sophie</a>: a web developer and personal website lover who writes about the tech industry and mental health, occasionally shares recipes, and posts about anything that takes her fancy.   
      </aside>
    </article>
{% endblock %}
