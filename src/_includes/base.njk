{%- from "macros/svg.njk" import svg -%}
<!DOCTYPE html>
<html lang="en" class="no-js">
  {% set cssFilename = global.cssFile() %}
  {% set jsFiles = global.jsFiles() %}
  <head>
    {% include "partials/meta.njk" %}
    <title>
      {% if not isHome %}
        {{ title }} -
      {% endif %}
      localghost</title>
    <script>
      const search = new URLSearchParams(window.location.search);
      const theme = search.get("theme") || localStorage.getItem("user-theme") || "city"
      document.documentElement.setAttribute("data-theme", theme);
      if (theme === "city") {
        const compare = Temporal.PlainTime.compare
        let stage;
        const timeNow = Temporal.Now.plainTimeISO()
        if (
          compare(timeNow, Temporal.PlainTime.from("21:00:00")) >= 0 &&
          compare(timeNow, Temporal.PlainTime.from("06:30:00")) < 0
        ) {
          stage = "night"
        } else if (compare(timeNow, Temporal.PlainTime.from("08:00:00")) < 0) {
          stage = "sunrise"
        } else if (compare(timeNow, Temporal.PlainTime.from("19:30:00")) < 0) {
          stage = "day"
        } else {
          stage = "sunset"
        }
        document.documentElement.setAttribute("data-time", stage)
      }
    </script>
    {% for k, filename in jsFiles %}
      <script rel="subresource" src={{ filename }} type="module"></script>
    {% endfor %}
    {% if extraCSS %}
      {% for file in extraCSS %}
        <link rel="stylesheet" type="text/css" href="/css/{{ file }}">
      {% endfor %}
    {% endif %}
    <link rel="preload" as="style" href={{ cssFilename }}>
    <link rel="stylesheet" type="text/css" href={{ cssFilename }}>
    <script data-goatcounter="https://localghost.goatcounter.com/count" async defer src="//gc.zgo.at/count.js"></script>
  </head>
  <body {% if isHome %} data-page="index" {% endif %}>
    {% include "partials/svg/defs.html" %}
    <div class="page-wrapper">
      {% include "partials/header.njk" %}
      <main>
        {% include "partials/nav.njk" %}
        <div class="content-wrapper">
          {% block content %}
            {{ content | safe }}
          {% endblock %}
        </div>
      </main>
      {% include "partials/footer.njk" %}
    </div>
  </body>
</html>